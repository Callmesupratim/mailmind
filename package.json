{
  "name": "mailmind",
  "version": "1.1.1",
  "description": "Gmail-connected AI email assistant powered by Groq",
  "author": "Phoenixtek Solution",
  "main": "main.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "electron": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.8.9",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "googleapis": "^134.0.0",
    "iconv-lite": "^0.4.24",
    "imapflow": "^1.3.7",
    "mailparser": "^3.9.9",
    "nodemailer": "^8.0.10"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.1.0"
  },
  "build": {
    "appId": "com.mailmind.app",
    "productName": "Mailmind",
    "asar": false,
    "npmRebuild": false,
    "files": [
      "main.js",
      "preload.js",
      "server/**/*",
      "public/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!bin/**/*"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": "bin/node.exe",
        "to": "node.exe"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mailmind",
      "license": "LICENSE.txt"
    },
    "win": {
      "icon": "icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "Callmesupratim",
      "repo": "mailmind"
    }
  }
}
